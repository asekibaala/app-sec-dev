# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your real values.
#
# NEVER commit .env to git. It contains passwords.
# .env.example is safe to commit — it has no real secrets, just instructions.
#
# On your Kali server:
#   cp .env.example .env
#   nano .env          ← fill in real values
#   chmod 600 .env     ← only your user can read it (security best practice)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection URL
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
#
# asyncpg  = the async Postgres driver (fast, non-blocking)
# USER     = the Postgres role you created for this app
# PASSWORD = strong password (use a password manager)
# HOST     = localhost (same machine) or IP of your DB server
# PORT     = 5432 is the default Postgres port
# DATABASE = the database name you created for this app
#
# Kali setup commands:
#   sudo -u postgres psql -c "CREATE USER recon_user WITH PASSWORD 'your_strong_password';"
#   sudo -u postgres psql -c "CREATE DATABASE recon_db OWNER recon_user;"
DATABASE_URL=postgresql+asyncpg://recon_user:your_strong_password@localhost:5432/recon_db

# App auth signing secret
# Used by FastAPI Users to sign JWT bearer tokens.
# Set this to a long random string outside local development.
APP_AUTH_SECRET=replace_this_with_a_long_random_secret_at_least_32_chars

# Authentication provider mode
# `local` uses FastAPI Users with credentials stored in PostgreSQL.
# `external_oidc` is reserved for a future secure AD/Entra/ADFS federation path.
AUTH_PROVIDER_MODE=local

# Future external OIDC provider settings
# These are placeholders for a future Windows AD integration through
# Entra ID / ADFS / another OIDC bridge rather than raw LDAP binds.
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
